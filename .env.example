# Redfox 抖音数据 API
# 申请地址：https://redfox.hk/settings/api-keys
REDFOX_API_KEY=ak_your_key_here
REDFOX_BASE_URL=https://redfox.hk

# 采集调度时区
# Cron 默认 09:00 Asia/Shanghai 跑
# 设置 RUN_CRON_NOW=1 可在 dev 启动时立即触发一次（用于联调）
# RUN_CRON_NOW=1

# ==========================================
# 数据库（dev / prod 二选一）
# ==========================================
# dev 留空 → 自动用本地 SQLite 文件 data/app.db（无需配置）
# Vercel 部署时设：
#   DATABASE_URL=libsql://your-db-name.turso.io
#   DATABASE_AUTH_TOKEN=eyJ...
# 申请 Turso：https://turso.tech/  （`turso db create` / `turso db tokens create`）

# ==========================================
# Vercel Cron 鉴权（仅 prod）
# ==========================================
# Vercel Cron 会自动读取此 env，并以 `Authorization: Bearer <CRON_SECRET>`
# 调用 /api/cron/run。本地不设 → 跳过鉴权。
# 生成方法：openssl rand -hex 32
# CRON_SECRET=
